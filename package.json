{
    "name": "webext-i18n",
    "version": "0.1.0",
    "description": "Internationalization toolkit for Chrome extensions — generate _locales/messages.json, validate translations, extract strings, and get coverage stats. CLI + library.",
    "author": "Zovo <hello@zovo.one>",
    "license": "MIT",
    "keywords": [
        "chrome-extension",
        "i18n",
        "internationalization",
        "localization",
        "messages-json",
        "_locales",
        "translation",
        "chrome-i18n",
        "manifest-v3",
        "browser-extension",
        "locale",
        "multilingual"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/theluckystrike/webext-i18n.git"
    },
    "homepage": "https://github.com/theluckystrike/webext-i18n",
    "bin": {
        "webext-i18n": "./dist/cli.js"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "jest",
        "lint": "eslint src --ext .ts",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "chalk": "^4.1.2",
        "commander": "^12.0.0",
        "glob": "^10.3.10"
    },
    "devDependencies": {
        "@types/chrome": "^0.1.37",
        "@types/jest": "^29.5.12",
        "@types/node": "^20.11.0",
        "@typescript-eslint/eslint-plugin": "^6.19.1",
        "@typescript-eslint/parser": "^6.19.1",
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.2",
        "typescript": "^5.3.3",
        "vitest": "^4.0.18"
    }
}
